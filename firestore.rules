rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidResource(data) {
      return data.keys().hasAll(['title', 'url', 'category']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 500 &&
             data.category is string && data.category.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10)) &&
             (!('addedBy' in data) || (data.addedBy == request.auth.uid));
    }

    function isValidStudyPlan(data) {
      return data.keys().hasAll(['userId', 'goal']) &&
             data.userId == request.auth.uid &&
             data.goal is string && data.goal.size() <= 500 &&
             (!('tasks' in data) || (data.tasks is list && data.tasks.size() <= 100));
    }

    // Resources Collection
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidResource(incoming()) && isValidId(resourceId);
      allow update: if isEmailVerified() && isOwner(existing().addedBy) && isValidResource(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'url', 'category', 'tags']);
      allow delete: if isOwner(existing().addedBy);
    }

    // Study Plans Collection
    match /users/{userId}/studyPlans/{planId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidStudyPlan(incoming()) && isValidId(planId);
      allow update: if isOwner(userId) && isValidStudyPlan(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['goal', 'tasks', 'updatedAt']);
      allow delete: if isOwner(userId);
    }
  }
}
